    <!-- Create Bean for a Employee1 class -->
    
    <bean id="emp1Bean" class="DemoOnSpring.DemoOnSpringS7.Employee1">
    <property name="empId" value="1"></property>
    <property name="empName" value="Aditya"/>
    <property name="empSalary" value="999.9"/>
    <property name="empActive" value="true"/>
    <!-- Injecting List value -->
    <property name="empSkills">
    <list>
    <value>Java</value>
    <value>Hibernate</value>
    <value>Spring</value>
     </list>
    </property>
    </bean>
    
    <bean id="emp2Bean" class="DemoOnSpring.DemoOnSpringS7.Employee1">
